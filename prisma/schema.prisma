datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  DOCTOR
  PHARMACIST
  ADMIN
}

enum ApprovalStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum PrescriptionStatus {
  PENDING
  VERIFIED
  REJECTED
  DISPENSED
}

enum OrderStatus {
  PENDING
  PACKING
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  CANCELLED
  REFUNDED
}

enum VerificationEntityType {
  DOCTOR
  PHARMACIST
  PHARMACY
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  doctorProfile     DoctorProfile?
  pharmacistProfile PharmacistProfile?
  adminProfile      AdminProfile?
  sessions          Session[]
  refreshTokens     RefreshToken[]
  otps              OTP[]
  passwordResets    PasswordResetToken[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  uploads           FileUpload[]

  @@index([email])
}

model Address {
  id         String   @id @default(uuid())
  line1      String
  line2      String?
  city       String
  state      String
  country    String
  postalCode String
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patients   Patient[]
  pharmacies Pharmacy[]
  orders     Order[]

  @@index([city, state])
}

model FileUpload {
  id         String   @id @default(uuid())
  fileUrl    String
  fileType   String
  mimeType   String
  uploadedBy String
  createdAt  DateTime @default(now())

  user          User                   @relation(fields: [uploadedBy], references: [id])
  documents     PrescriptionDocument[]
  verifications VerificationRequest[]

  @@index([uploadedBy])
}

model AdminProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  name           String
  employeeId     String   @unique
  department     String
  contactDetails String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews VerificationRequest[]
}

model Patient {
  id          String    @id @default(uuid())
  name        String
  dateOfBirth DateTime
  gender      String
  phone       String    @unique
  email       String?   @unique
  addressId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  address        Address          @relation(fields: [addressId], references: [id])
  prescriptions  Prescription[]
  medicalHistory MedicalHistory[]
  allergies      Allergy[]
  orders         Order[]

  @@index([phone])
  @@index([addressId])
}

model DoctorProfile {
  id              String         @id @default(uuid())
  userId          String         @unique
  name            String
  email           String         @unique
  specialization  String
  licenseNumber   String         @unique
  phone           String
  status          ApprovalStatus @default(PENDING)
  regNo           String?
  hospital        String?
  experience      String?
  consultationFee Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@index([status])
}

model PharmacistProfile {
  id              String         @id @default(uuid())
  userId          String         @unique
  name            String
  email           String         @unique
  licenseNumber   String         @unique
  phone           String
  qualifications  String
  status          ApprovalStatus @default(PENDING)
  pharmacyLicense String?
  regNo           String?
  experience      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pharmacies Pharmacy[]

  @@index([status])
}

model Pharmacy {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  phone         String
  addressId     String
  licenseNumber String         @unique
  status        ApprovalStatus @default(PENDING)
  drugLicense   String?
  gst           String?
  ownerName     String?
  managerId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  address     Address             @relation(fields: [addressId], references: [id])
  manager     PharmacistProfile   @relation(fields: [managerId], references: [id])
  inventories PharmacyInventory[]
  orders      Order[]

  @@index([status])
  @@index([addressId])
  @@index([managerId])
}

model VerificationRequest {
  id                   String                 @id @default(uuid())
  entityType           VerificationEntityType
  entityId             String
  status               ApprovalStatus         @default(PENDING)
  remarks              String?
  supportingDocumentId String?
  reviewedBy           String?
  submittedAt          DateTime               @default(now())
  reviewedAt           DateTime?

  document FileUpload?   @relation(fields: [supportingDocumentId], references: [id])
  reviewer AdminProfile? @relation(fields: [reviewedBy], references: [id])

  @@index([entityType, entityId])
  @@index([status])
  @@index([reviewedBy])
  @@index([supportingDocumentId])
}

model MedicineCategory {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  medicines Medicine[]
}

model MedicineManufacturer {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  medicines Medicine[]
}

model Medicine {
  id                   String   @id @default(uuid())
  name                 String   @unique
  genericName          String?
  brandName            String?
  strength             String?
  dosageForm           String?
  packSize             String?
  requiresPrescription Boolean  @default(false)
  description          String?
  imageUrl             String?
  barcode              String?
  categoryId           String
  manufacturerId       String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  category     MedicineCategory     @relation(fields: [categoryId], references: [id])
  manufacturer MedicineManufacturer @relation(fields: [manufacturerId], references: [id])
  inventories  PharmacyInventory[]
  rxItems      PrescriptionItem[]
  orderItems   OrderItem[]

  @@index([name])
  @@index([categoryId])
  @@index([manufacturerId])
}

model PharmacyInventory {
  id         String   @id @default(uuid())
  pharmacyId String
  medicineId String
  stock      Int
  minStock   Int
  price      Float
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pharmacy     Pharmacy               @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicine     Medicine               @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  batches      InventoryBatch[]
  transactions InventoryTransaction[]

  @@unique([pharmacyId, medicineId])
  @@index([pharmacyId, medicineId])
}

enum TransactionType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  RETURN
  EXPIRED
}

model InventoryTransaction {
  id          String          @id @default(uuid())
  inventoryId String
  quantity    Int
  type        TransactionType
  reason      String?
  performedBy String?
  createdAt   DateTime        @default(now())

  inventory PharmacyInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([type])
  @@index([createdAt])
}

model InventoryBatch {
  id              String   @id @default(uuid())
  inventoryId     String
  batchNumber     String
  manufactureDate DateTime
  expiryDate      DateTime
  purchasePrice   Float
  sellingPrice    Float
  quantity        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inventory PharmacyInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([expiryDate])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OTP {
  id        String    @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, code])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Allergy {
  id        String   @id @default(uuid())
  patientId String
  allergen  String
  severity  String
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model MedicalHistory {
  id          String   @id @default(uuid())
  patientId   String
  condition   String
  diagnosedAt DateTime
  createdAt   DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Prescription {
  id        String             @id @default(uuid())
  doctorId  String
  patientId String
  status    PrescriptionStatus @default(PENDING)
  notes     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  doctor    DoctorProfile          @relation(fields: [doctorId], references: [id])
  patient   Patient                @relation(fields: [patientId], references: [id])
  items     PrescriptionItem[]
  orders    Order[]
  documents PrescriptionDocument[]

  @@index([doctorId, patientId, status])
}

model PrescriptionDocument {
  id             String   @id @default(uuid())
  prescriptionId String
  fileUploadId   String
  createdAt      DateTime @default(now())

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  fileUpload   FileUpload   @relation(fields: [fileUploadId], references: [id])

  @@index([prescriptionId])
  @@index([fileUploadId])
}

model PrescriptionItem {
  id             String  @id @default(uuid())
  prescriptionId String
  medicineId     String
  dosage         String
  frequency      String?
  duration       String

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicine     Medicine     @relation(fields: [medicineId], references: [id])

  @@index([prescriptionId])
  @@index([medicineId])
}

model Order {
  id                String      @id @default(uuid())
  prescriptionId    String
  pharmacyId        String?
  patientId         String
  shippingAddressId String
  totalCost         Float
  status            OrderStatus @default(PENDING)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  prescription Prescription  @relation(fields: [prescriptionId], references: [id])
  pharmacy     Pharmacy?     @relation(fields: [pharmacyId], references: [id])
  patient      Patient       @relation(fields: [patientId], references: [id])
  address      Address       @relation(fields: [shippingAddressId], references: [id])
  items        OrderItem[]
  payment      Payment?
  invoice      Invoice?
  logs         ActivityLog[]

  @@index([status, createdAt])
  @@index([patientId])
  @@index([prescriptionId])
  @@index([pharmacyId])
  @@index([shippingAddressId])
}

model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  medicineId String
  quantity   Int
  price      Float

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id])

  @@index([orderId])
  @@index([medicineId])
}

model Payment {
  id             String        @id @default(uuid())
  orderId        String        @unique
  amount         Float
  status         PaymentStatus @default(PENDING)
  paymentMethod  String
  paymentGateway String?
  transactionId  String?
  failureReason  String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Invoice {
  id            String   @id @default(uuid())
  orderId       String   @unique
  invoiceNumber String   @unique
  pdfUrl        String?
  createdAt     DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  title     String?
  body      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(uuid())
  orderId   String
  status    String
  notes     String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
